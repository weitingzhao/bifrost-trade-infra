# Copy to repo-secret.yaml and set githubToken before apply (private repo only).
# kubectl apply -f k8s/cicd/argocd/repo-secret.yaml -n cicd
apiVersion: v1
kind: Secret
metadata:
  name: repo-bifrost-trade-infra
  namespace: cicd
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: git
  url: https://github.com/weitingzhao/bifrost-trade-infra.git
  username: git
  password: "<GITHUB_PAT>"
