# Copy to secret.yaml (do not commit) and apply before bootstrap-gitea-mirrors.sh
# kubectl apply -f k8s/cicd/gitea/secret.yaml -n cicd
#
# Gitea is primary Git for Tekton/Argo (LAN). GitHub repos are pull-mirrors only.
# LAN UI (after S7.5): http://192.168.10.73:30300
# In-cluster: http://gitea.cicd.svc.cluster.local:3000
apiVersion: v1
kind: Secret
metadata:
  name: gitea-bootstrap
  namespace: cicd
  labels:
    bifrost.io/component: gitea
type: Opaque
stringData:
  # Gitea admin API (create org + mirrors). Gitea UI → Settings → Applications → Generate Token
  # Required scopes (check all):
  #   read:user  write:user
  #   read:organization  write:organization
  #   read:repository  write:repository
  gitea_admin_token: "<GITEA_ADMIN_TOKEN>"
  # Optional — required for private GitHub repos when creating pull mirrors.
  github_pat: "<GITHUB_PAT>"
---
# Tekton git clone credentials (HTTP basic against in-cluster Gitea).
apiVersion: v1
kind: Secret
metadata:
  name: gitea-git-credentials
  namespace: cicd
  labels:
    bifrost.io/component: gitea
  annotations:
    tekton.dev/git-0: http://gitea.cicd.svc.cluster.local:3000
type: kubernetes.io/basic-auth
stringData:
  username: "<GITEA_CI_USER>"
  password: "<GITEA_CI_TOKEN_OR_PASSWORD>"
