# CI build — context must contain sibling repos from Gitea:
#   bifrost-trade-core/  bifrost-trade-worker/  bifrost-trade-socket/  bifrost-trade-api/
# Build arg API_DOMAIN selects which FastAPI domain this image runs (monitor|massive|...).
# Layered pip install matches docker/Dockerfile.prod-local-api (non-editable; deps resolved).
FROM python:3.11-slim AS base-api

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev procps \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY bifrost-trade-core/pyproject.toml bifrost-trade-core/README.md /build/bifrost-trade-core/
COPY bifrost-trade-core/src /build/bifrost-trade-core/src
COPY bifrost-trade-core/scripts /build/bifrost-trade-core/scripts
RUN pip install --no-cache-dir /build/bifrost-trade-core \
    && pip install --no-cache-dir "psycopg2-binary>=2.9.0" "PyYAML>=6.0" "redis>=4.5.0" "py_vollib>=1.0.1"

COPY bifrost-trade-worker/pyproject.toml bifrost-trade-worker/README.md /build/bifrost-trade-worker/
COPY bifrost-trade-worker/src /build/bifrost-trade-worker/src
COPY bifrost-trade-worker/scripts /build/bifrost-trade-worker/scripts
RUN pip install --no-cache-dir --no-deps /build/bifrost-trade-worker \
    && pip install --no-cache-dir "celery[redis]>=5.3.0" "flower>=2.0.0"

COPY bifrost-trade-socket/pyproject.toml bifrost-trade-socket/README.md /build/bifrost-trade-socket/
COPY bifrost-trade-socket/src /build/bifrost-trade-socket/src
COPY bifrost-trade-socket/scripts /build/bifrost-trade-socket/scripts
RUN pip install --no-cache-dir --no-deps /build/bifrost-trade-socket \
    && pip install --no-cache-dir "ib_insync>=0.9.86" "websockets>=12.0" "aioredis>=2.0"

FROM base-api AS api

COPY bifrost-trade-api/pyproject.toml /build/bifrost-trade-api/
COPY bifrost-trade-api/src /build/bifrost-trade-api/src
COPY bifrost-trade-api/scripts /build/bifrost-trade-api/scripts
RUN pip install --no-cache-dir --no-deps /build/bifrost-trade-api \
    && pip install --no-cache-dir "fastapi>=0.100.0" "uvicorn[standard]>=0.22.0" "kubernetes>=28.0.0"

WORKDIR /build/bifrost-trade-api

ARG API_DOMAIN=monitor
ENV API_DOMAIN=${API_DOMAIN} \
    PYTHONUNBUFFERED=1 \
    BIFROST_CONFIG=/app/config/config.stg.yaml \
    BIFROST_ENV=stg

EXPOSE 8765

CMD ["sh", "-c", "python scripts/run_server.py \"${API_DOMAIN}\""]
