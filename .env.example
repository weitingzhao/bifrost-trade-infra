# ============================================================
# Bifrost Trade — 环境变量模板
# 复制为 .env 并填写真实值（.env 已在 .gitignore 中排除）
# ============================================================

# --- 版本控制 ---
BIFROST_CORE_REF=main
BIFROST_WORKER_REF=main
BIFROST_SOCKET_REF=main
GITHUB_ORG=YOUR_ORG

# --- 本地 Session 0 / 2C-A 冒烟（不 pip 从 GitHub；用同级 monorepo 源码构建）---
# 1 或未设置 GITHUB_ORG 时 make prod-preflight 会自动走 local build
BIFROST_BUILD_LOCAL=1

# --- Docker build（local prod 分层 + pip cache mount）---
DOCKER_BUILDKIT=1

# --- 环境 ---
BIFROST_ENV=dev          # dev | prod（make prod-preflight 使用 prod）

# --- Prod 基础设施模式（Phase 2C）---
# host (默认): LAN PG (192.168.10.80) + 本机/LAN Redis；make sync-prod-config → config.prod.yaml
# embedded-infra: compose 内 PG+Redis（2C-A.1 推荐：与 Legacy .70 Redis 隔离，避免 Ops lease 冲突）
BIFROST_PROD_INFRA=host

# --- 2C-A.1 Docker 控制面 ---
# config.prod.yaml: ops.executor_mode=docker（api-ops 需挂载 docker.sock + /infra）
COMPOSE_PROJECT_NAME=bifrost-trade-infra
# 本地 2C-A.1 验收建议:
#   BIFROST_PROD_INFRA=embedded-infra
#   REDIS_HOST=redis
#   REDIS_URL=redis://redis:6379/0
#   make prod-embedded-infra && make verify-2c-a1

# --- Dev 基础设施模式 ---
# host (默认): 使用本机 brew PG/Redis 或 LAN 共享 Dev 库（与 bifrost-trade-core/config/config.dev.yaml 对齐）
# docker-infra: 额外启动隔离的空 postgres+redis 容器（make dev-docker-infra）
BIFROST_DEV_INFRA=host

# --- PostgreSQL（写入 config.dev.yaml；容器内通过 host/LAN 地址连接）---
# 共享 Dev DB（推荐，有真实 account 数据）:
POSTGRES_HOST=192.168.10.80
POSTGRES_PORT=5432
POSTGRES_USER=bifrost
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=options_db          # dev 库名
# POSTGRES_DB=bifrost_prod      # prod 库名（sync-prod-config 默认）
# 本机 brew postgres 时用: POSTGRES_HOST=host.docker.internal

# --- Redis ---
REDIS_HOST=192.168.10.70
REDIS_PORT=6379
REDIS_URL=redis://192.168.10.70:6379/0

# docker-infra 模式时改为服务名:
# POSTGRES_HOST=postgres
# REDIS_HOST=redis
# REDIS_URL=redis://redis:6379/0
# BIFROST_DEV_INFRA=docker-infra

# --- Interactive Brokers (sync → config.*.yaml ib.host + ib.secondary) ---
# Legacy reference: bifrost-trader-engine/config/config.prod.yaml (Host .34) / config.dev.yaml (Host .30)
# Settings → IB Connection reads Monitor GET /status → config.ib_client (from merged YAML).
IB_HOST=192.168.10.30
IB_SECONDARY_HOST=192.168.10.33
IB_PORT_TYPE=tws_live
IB_SECONDARY_PORT_TYPE=tws_live
# Prod client_ids (Legacy config.prod.yaml); dev uses 110/101/120/… — see sync_dev_config defaults
IB_CLIENT_ID_DAEMON=10
IB_CLIENT_ID_LISTENER=1
IB_CLIENT_ID_OPERATOR=20
IB_CLIENT_ID_WORKER=40
IB_CLIENT_ID_INGESTOR=50
IB_CLIENT_ID_ACCOUNT=60
IB_SECONDARY_CLIENT_ID_LISTENER=1
IB_SECONDARY_CLIENT_ID_OPERATOR=20
IB_SECONDARY_CLIENT_ID_ACCOUNT=60
# 连真实 TWS 时设为 false，否则 monitor 跳过 IB 自检（Market Streams 显示 offline）
BIFROST_SKIP_MONITOR_IB=false

# --- Polygon (Massive) ---
# Dev: `make sync-dev-config` imports from ../bifrost-trader-engine/config/config.yaml when still CHANGE_ME.
# Or copy massive.api_key from legacy config.yaml manually. Also accepts MASSIVE_API_KEY.
POLYGON_API_KEY=CHANGE_ME

# --- STG K3s IB client_ids (210 range — isolated from prod 10 / dev 110) ---
# STG_IB_CLIENT_ID_DAEMON=210
# STG_IB_CLIENT_ID_LISTENER=201
# STG_IB_CLIENT_ID_OPERATOR=220
# STG_IB_CLIENT_ID_INGESTOR=250
# STG_IB_CLIENT_ID_ACCOUNT=260

# --- Ops API auth (optional — override YAML ops.auth.tokens) ---
# Default dev tokens live in config/config.dev.yaml (migrated from legacy engine).
# Paste operator token in UI: Settings → API Health → Authenticate
# OPS_OPERATOR_TOKEN=
# OPS_ADMIN_TOKEN=

# --- Celery ---
CELERY_BROKER_URL=redis://192.168.10.70:6379/1
CELERY_RESULT_BACKEND=redis://192.168.10.70:6379/2

# --- 服务端口（内部；Nginx 对外统一暴露）---
PORT_MONITOR=8765
PORT_MASSIVE=8766
PORT_DOCS=8767
PORT_OPS=8768
PORT_TRADING=8769
PORT_STRATEGY=8770
PORT_PORTFOLIO=8771
PORT_MARKET=8772
PORT_RESEARCH=8773
PORT_FRONTEND=80
