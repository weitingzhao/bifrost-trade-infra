# ============================================================
# Bifrost Trade — 环境变量模板
# 复制为 .env 并填写真实值（.env 已在 .gitignore 中排除）
# ============================================================

# --- 版本控制 ---
BIFROST_CORE_REF=main
BIFROST_WORKER_REF=main
BIFROST_SOCKET_REF=main
GITHUB_ORG=YOUR_ORG

# --- 环境 ---
BIFROST_ENV=dev          # dev | prod

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=bifrost
POSTGRES_PASSWORD=bifrost_dev
POSTGRES_DB=bifrost_dev  # bifrost_dev | bifrost_prod

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Interactive Brokers ---
IB_HOST=host.docker.internal   # TWS/Gateway 在 Mac Mini 上运行时
IB_PORT=7497                   # TWS paper: 7497, live: 7496; Gateway paper: 4002, live: 4001
IB_CLIENT_ID_INGESTOR=1
IB_CLIENT_ID_ACCOUNT=2
IB_CLIENT_ID_OPERATOR=3

# --- Polygon (Massive) ---
POLYGON_API_KEY=CHANGE_ME

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- 服务端口（内部；Nginx 对外统一暴露）---
PORT_MONITOR=8765
PORT_MASSIVE=8766
PORT_DOCS=8767
PORT_OPS=8768
PORT_TRADING=8769
PORT_STRATEGY=8770
PORT_PORTFOLIO=8771
PORT_MARKET=8772
PORT_RESEARCH=8773
PORT_FRONTEND=80
