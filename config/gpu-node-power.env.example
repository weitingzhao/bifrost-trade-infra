# gpu-server (4090 @ 192.168.10.60) — Wake-on-LAN + idle shutdown (Step 3).
# Copy to config/gpu-node-power.env and adjust. Do not commit secrets.
#
# Power manager runs on an always-on host (default: bootstrap @ 192.168.10.73).

GPU_NODE_NAME=gpu-server
GPU_SSH_HOST=vision@192.168.10.60
WOL_MAC=c8:7f:54:5b:b8:33

# Poll interval (seconds)
POLL_INTERVAL=60

# Power off after this many minutes with no user workloads on gpu-server
IDLE_MINUTES=30

# Max wait after WOL before giving up (seconds)
WAKE_TIMEOUT=600

# Kubeconfig on bootstrap (install script sets /home/vision/.kube/config for systemd User=vision)
KUBECONFIG=/home/vision/.kube/config

# Set 0 to disable auto power-off (wake-only mode)
AUTO_POWEROFF=1
