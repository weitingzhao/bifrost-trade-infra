{
	// Bifrost Trade — 多 repo 工作区
	// Folder 顺序 = 依赖方向：infra → core → socket → worker → api → frontend → engine(只读)
	"folders": [
		{
			"name": "🏗️ infra · 部署中心 — Compose / Nginx / 全局配置",
			"path": "."
		},
		{
			"name": "📦 core · 共享库 — bifrost_core · 无进程入口",
			"path": "../bifrost-trade-core",
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.testing.pytestArgs": ["-m", "not ib and not db"]
			}
		},
		{
			"name": "🔌 socket · 边缘连接 — IB Ingestor/Operator + Massive WS → Redis",
			"path": "../bifrost-trade-socket",
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.testing.pytestArgs": ["-m", "not ib"]
			}
		},
		{
			"name": "⚡ worker · 后台引擎 — GsTrading Daemon + Celery 数据管道",
			"path": "../bifrost-trade-worker",
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.testing.pytestArgs": ["-m", "not ib and not db"]
			}
		},
		{
			"name": "🌐 api · 只读 HTTP — FastAPI 9 域 · :8765–8773",
			"path": "../bifrost-trade-api",
			"settings": {
				"python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
				"python.testing.pytestArgs": ["-m", "not ib and not db"]
			}
		},
		{
			"name": "🖥️ frontend · 监控 UI — React 18 · Vite · :5173",
			"path": "../bifrost-trade-frontend"
		},
		{
			"name": "🔒 engine · 只读参考 — 重构蓝本 · 禁止修改",
			"path": "../bifrost-trader-engine",
			"settings": {
				"python.testing.pytestEnabled": false,
				"python.testing.unittestEnabled": false
			}
		}
	],
	"settings": {
		"python.testing.pytestEnabled": true,
		"python.testing.unittestEnabled": false,
		"files.readonlyInclude": {
			"**/bifrost-trader-engine/**": true
		},
		"files.readonlyFromPermissions": false,
		"explorer.compactFolders": false,
		"explorer.sortOrder": "default",
		"editor.formatOnSave": true,
		"[python]": {
			"editor.defaultFormatter": "charliermarsh.ruff"
		},
		"[typescript]": {
			"editor.defaultFormatter": "esbenp.prettier-vscode"
		},
		"[typescriptreact]": {
			"editor.defaultFormatter": "esbenp.prettier-vscode"
		},
		"search.exclude": {
			"**/node_modules": true,
			"**/__pycache__": true,
			"**/.venv": true,
			"**/dist": true,
			"**/build": true,
			"**/*.egg-info": true,
			"**/site": true
		},
		"explorer.fileNesting.enabled": true,
		"explorer.fileNesting.expand": false,
		"explorer.fileNesting.patterns": {
			"pyproject.toml": "requirements*.txt, setup.py, setup.cfg, uv.lock",
			"docker-compose.yml": "docker-compose*.yml, .env.example, .env, Makefile",
			"package.json": "package-lock.json, yarn.lock, tsconfig*.json, vite.config.*",
			"CLAUDE.md": "README.md, AGENTS.md, LICENSE",
			"bifrost-trade.code-workspace": "docs/MIGRATION_TRACKING.md"
		}
	},
	"extensions": {
		"recommendations": [
			"ms-python.python",
			"charliermarsh.ruff",
			"ms-python.mypy-type-checker",
			"esbenp.prettier-vscode",
			"dbaeumer.vscode-eslint",
			"ms-azuretools.vscode-docker"
		]
	}
}
