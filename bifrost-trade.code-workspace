{
	// Bifrost — multi-repo workspace
	// Explorer order: Environment (control plane) → Business (data plane) → Reference
	"folders": [
		{
			"name": "🛡️ ui · 共享框架 — @bifrost/ui · Shell · Dense tokens",
			"path": "../bifrost-ui"
		},
		{
			"name": "🛡️ platform · 环境控制面 — Go API :8780 · Console :5180",
			"path": "../bifrost-platform"
		},
		{
			"name": "🛡️ infra · 部署 / Goal — Compose · Nginx · MkDocs :8050",
			"path": "."
		},
		{
			"name": "📊 frontend · 业务监控 UI — React · Trade SPA :5173",
			"path": "../bifrost-trade-frontend"
		},
		{
			"name": "📦 core · 共享库 — bifrost_core",
			"path": "../bifrost-trade-core"
		},
		{
			"name": "🔌 socket · IB / Massive 边缘 — Redis",
			"path": "../bifrost-trade-socket"
		},
		{
			"name": "⚡ worker · Daemon + Celery",
			"path": "../bifrost-trade-worker"
		},
		{
			"name": "🌐 api · FastAPI 9 域 — :8765–8773",
			"path": "../bifrost-trade-api"
		},
		{
			"path": "../bifrost-platform-plugin"
		}
	],
	"settings": {
		"python.testing.pytestEnabled": true,
		"python.testing.unittestEnabled": false,
		"explorer.compactFolders": false,
		"explorer.sortOrder": "default",
		"explorer.excludeGitIgnore": false,
		"editor.formatOnSave": true,
		"[python]": {
			"editor.defaultFormatter": "charliermarsh.ruff"
		},
		"[typescript]": {
			"editor.defaultFormatter": "esbenp.prettier-vscode"
		},
		"[typescriptreact]": {
			"editor.defaultFormatter": "esbenp.prettier-vscode"
		},
		"search.exclude": {
			"**/node_modules": true,
			"**/__pycache__": true,
			"**/.venv": true,
			"**/dist": true,
			"**/build": true,
			"**/*.egg-info": true,
			"**/site": true
		},
		"explorer.fileNesting.enabled": true,
		"explorer.fileNesting.expand": false,
		"explorer.fileNesting.patterns": {
			"pyproject.toml": "requirements*.txt, setup.py, setup.cfg, uv.lock",
			"docker-compose.yml": "docker-compose*.yml, .env.example, Makefile",
			"package.json": "package-lock.json, yarn.lock, tsconfig*.json, vite.config.*",
			"CLAUDE.md": "README.md, AGENTS.md, LICENSE",
			"bifrost-trade.code-workspace": "docs/MIGRATION_TRACKING.md"
		}
	},
	"extensions": {
		"recommendations": [
			"ms-python.python",
			"charliermarsh.ruff",
			"ms-python.mypy-type-checker",
			"esbenp.prettier-vscode",
			"dbaeumer.vscode-eslint",
			"ms-azuretools.vscode-docker"
		]
	}
}